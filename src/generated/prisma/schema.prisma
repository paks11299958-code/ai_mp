generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               Int                 @id @default(autoincrement())
  email            String              @unique
  password         String
  username         String?
  role             String              @default("USER")
  resetToken       String?
  resetTokenExpiry DateTime?
  createdAt        DateTime            @default(now())
  personas         Persona[]
  sessions         ChatSession[]
  memories         UserMemory[]
  personaXps       UserPersonaXp[]
  boardPosts       BoardPost[]
  boardReplies     BoardReply[]
  swingAnalyses    UserSwingAnalysis[]
}

model UserPersonaXp {
  userId    Int
  personaId String
  xp        Int     @default(0)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  persona   Persona @relation(fields: [personaId], references: [id], onDelete: Cascade)

  @@id([userId, personaId])
}

model UserMemory {
  id        Int                         @id @default(autoincrement())
  userId    Int
  content   String
  embedding Unsupported("vector(768)")?
  category  String?
  createdAt DateTime                    @default(now())
  user      User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Persona {
  id                String                @id @default(cuid())
  name              String
  jobTitle          String?
  description       String?
  systemInstruction String
  identityPrompt    String?
  iconName          String                @default("Bot")
  colorClass        String                @default("from-blue-500 to-cyan-500")
  order             Int                   @default(0)
  imageUrl          String?
  introVideoUrl     String?
  isDefault         Boolean               @default(false)
  isVisible         Boolean               @default(true)
  createdBy         Int?
  user              User?                 @relation(fields: [createdBy], references: [id], onDelete: SetNull)
  createdAt         DateTime              @default(now())
  sessions          ChatSession[]
  images            PersonaImage[]
  personaXps        UserPersonaXp[]
  knowledge         PersonaKnowledge[]
  boardPosts        BoardPost[]
  triggerVideos     PersonaTriggerVideo[]
  swingAnalyses     UserSwingAnalysis[]
}

model PersonaImage {
  id            Int            @id @default(autoincrement())
  personaId     String
  imageUrl      String
  description   String?
  isMain        Boolean        @default(false)
  order         Int            @default(0)
  requiredLevel Int            @default(1)
  createdAt     DateTime       @default(now())
  persona       Persona        @relation(fields: [personaId], references: [id], onDelete: Cascade)
  videos        PersonaVideo[]
}

model PersonaVideo {
  id            Int          @id @default(autoincrement())
  imageId       Int
  videoUrl      String
  title         String?
  order         Int          @default(0)
  requiredLevel Int          @default(1)
  createdAt     DateTime     @default(now())
  image         PersonaImage @relation(fields: [imageId], references: [id], onDelete: Cascade)
}

model ChatSession {
  id        Int                  @id @default(autoincrement())
  userId    Int
  personaId String
  title     String?
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  persona   Persona              @relation(fields: [personaId], references: [id], onDelete: Cascade)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  messages  Message[]
  summary   ConversationSummary?
}

model Message {
  id        Int         @id @default(autoincrement())
  sessionId Int
  role      String
  text      String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())
}

model ConversationSummary {
  id           Int         @id @default(autoincrement())
  sessionId    Int         @unique
  summary      String
  messageCount Int
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  session      ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model AppConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model PersonaKnowledge {
  id        Int                         @id @default(autoincrement())
  personaId String
  sourceId  String?
  title     String?
  content   String
  embedding Unsupported("vector(768)")?
  createdAt DateTime                    @default(now())
  persona   Persona                     @relation(fields: [personaId], references: [id], onDelete: Cascade)
}

model PersonaTriggerVideo {
  id          Int      @id @default(autoincrement())
  personaId   String
  videoUrl    String
  title       String?
  description String?
  keywords    String
  tag         String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  persona     Persona  @relation(fields: [personaId], references: [id], onDelete: Cascade)
}

model BoardPost {
  id        Int          @id @default(autoincrement())
  userId    Int
  personaId String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  persona   Persona      @relation(fields: [personaId], references: [id], onDelete: Cascade)
  title     String
  content   String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  replies   BoardReply[]
}

model UserSwingAnalysis {
  id           Int      @id @default(autoincrement())
  userId       Int
  personaId    String
  fileName     String?
  analysisJson String
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  persona      Persona  @relation(fields: [personaId], references: [id], onDelete: Cascade)
}

model BoardReply {
  id           Int       @id @default(autoincrement())
  postId       Int
  post         BoardPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId       Int
  user         User      @relation(fields: [userId], references: [id])
  isAdminReply Boolean   @default(false)
  content      String
  createdAt    DateTime  @default(now())
}

model Announcement {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  category  String   @default("update")
  isPinned  Boolean  @default(false)
  isVisible Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
